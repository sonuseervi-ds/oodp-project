<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EduPulse — Student Performance Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --surface2: #1a1a26;
    --surface3: #22223a;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.13);
    --text: #f0eeff;
    --muted: #8b8aaa;
    --dim: #4a4a6a;
    --accent: #7c6eff;
    --accent2: #b8aaff;
    --teal: #00d4aa;
    --coral: #ff6b6b;
    --amber: #ffb347;
    --blue: #4fc3f7;
    --pink: #f06292;
    --green: #69f0ae;
    --radius: 14px;
    --radius-sm: 8px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Subtle background grid */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(124,110,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124,110,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .app { position: relative; z-index: 1; display: flex; min-height: 100vh; }

  /* ── SIDEBAR ── */
  .sidebar {
    width: 260px;
    flex-shrink: 0;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--dim) transparent;
  }

  .logo {
    padding: 28px 24px 20px;
    border-bottom: 1px solid var(--border);
  }
  .logo-mark {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 22px;
    color: var(--text);
    letter-spacing: -0.5px;
  }
  .logo-mark span { color: var(--accent); }
  .logo-sub { font-size: 11px; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; margin-top: 2px; }

  .nav { padding: 16px 12px; flex: 1; }
  .nav-label { font-size: 10px; color: var(--dim); letter-spacing: 2px; text-transform: uppercase; padding: 8px 12px 6px; }

  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: var(--radius-sm);
    cursor: pointer; font-size: 14px; color: var(--muted);
    transition: all 0.2s; margin-bottom: 2px;
  }
  .nav-item:hover { background: var(--surface2); color: var(--text); }
  .nav-item.active { background: rgba(124,110,255,0.15); color: var(--accent2); }
  .nav-icon { font-size: 16px; width: 20px; text-align: center; }

  .student-list { padding: 0 12px 16px; }
  .student-item {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 12px; border-radius: var(--radius-sm);
    cursor: pointer; transition: all 0.2s; margin-bottom: 1px;
  }
  .student-item:hover { background: var(--surface2); }
  .student-item.selected { background: rgba(124,110,255,0.12); }
  .student-avatar {
    width: 30px; height: 30px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 600; flex-shrink: 0;
    font-family: 'Syne', sans-serif;
  }
  .student-name { font-size: 13px; color: var(--muted); flex: 1; }
  .student-grade {
    font-family: 'DM Mono', monospace;
    font-size: 11px; font-weight: 500;
    padding: 2px 7px; border-radius: 20px;
  }

  /* ── MAIN ── */
  .main { margin-left: 260px; flex: 1; padding: 32px 36px; max-width: 1200px; }

  /* ── TOP BAR ── */
  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 32px;
  }
  .page-title { font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 700; }
  .page-title span { color: var(--accent); }

  .search-bar {
    display: flex; align-items: center; gap: 10px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 50px; padding: 8px 16px;
    font-size: 13px; color: var(--muted);
    cursor: pointer; transition: border-color 0.2s;
  }
  .search-bar:hover { border-color: var(--border2); }

  /* ── STAT CARDS ── */
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }

  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px 22px;
    position: relative; overflow: hidden; cursor: default;
    transition: border-color 0.25s, transform 0.2s;
  }
  .stat-card:hover { border-color: var(--border2); transform: translateY(-2px); }
  .stat-card::after {
    content: ''; position: absolute;
    top: 0; left: 0; right: 0; height: 2px;
  }
  .stat-card.c1::after { background: linear-gradient(90deg, var(--accent), var(--accent2)); }
  .stat-card.c2::after { background: linear-gradient(90deg, var(--teal), #00f5c3); }
  .stat-card.c3::after { background: linear-gradient(90deg, var(--coral), #ff9a9a); }
  .stat-card.c4::after { background: linear-gradient(90deg, var(--amber), #ffd47a); }

  .stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px; }
  .stat-value { font-family: 'Syne', sans-serif; font-size: 32px; font-weight: 700; line-height: 1; margin-bottom: 6px; }
  .stat-sub { font-size: 12px; color: var(--muted); }
  .stat-icon { position: absolute; top: 18px; right: 18px; font-size: 22px; opacity: 0.3; }

  /* ── GRID LAYOUT ── */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 20px; }

  .card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 22px;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: var(--border2); }
  .card-title {
    font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 600;
    color: var(--text); margin-bottom: 18px;
    display: flex; align-items: center; gap: 8px;
  }
  .card-title .dot { width: 6px; height: 6px; border-radius: 50%; }

  /* Chart containers */
  .chart-wrap { position: relative; width: 100%; }

  /* ── STUDENT DETAIL PANEL ── */
  .detail-header {
    display: flex; align-items: center; gap: 16px; margin-bottom: 22px;
  }
  .detail-avatar {
    width: 56px; height: 56px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 700; font-family: 'Syne', sans-serif;
  }
  .detail-name { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; }
  .detail-meta { font-size: 12px; color: var(--muted); margin-top: 3px; }
  .grade-badge {
    margin-left: auto;
    font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 800;
    width: 60px; height: 60px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    border: 2px solid;
  }

  /* Subject scores */
  .subject-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .subject-name { font-size: 13px; color: var(--muted); width: 85px; flex-shrink: 0; }
  .subject-bar-wrap { flex: 1; background: var(--surface3); border-radius: 20px; height: 8px; overflow: hidden; }
  .subject-bar { height: 100%; border-radius: 20px; transition: width 0.8s cubic-bezier(0.4,0,0.2,1); }
  .subject-score { font-family: 'DM Mono', monospace; font-size: 13px; font-weight: 500; width: 36px; text-align: right; }

  /* Attendance ring */
  .attendance-ring-wrap { display: flex; align-items: center; justify-content: center; padding: 10px 0; }

  /* ── TABLE ── */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; }
  th {
    font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px;
    color: var(--dim); font-weight: 500;
    padding: 8px 12px; text-align: left;
    border-bottom: 1px solid var(--border);
  }
  td {
    padding: 11px 12px; font-size: 13px; color: var(--muted);
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }
  tr:hover td { background: rgba(124,110,255,0.04); }
  tr.selected-row td { background: rgba(124,110,255,0.08); }
  td:first-child { color: var(--text); }
  .rank-badge {
    font-family: 'DM Mono', monospace; font-size: 11px;
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--surface3);
  }
  .perf-pill {
    font-size: 11px; padding: 3px 9px; border-radius: 20px;
    font-weight: 500; display: inline-block;
  }
  .perf-A { background: rgba(105,240,174,0.15); color: var(--green); }
  .perf-B { background: rgba(79,195,247,0.15); color: var(--blue); }
  .perf-C { background: rgba(255,179,71,0.15); color: var(--amber); }
  .perf-D { background: rgba(255,107,107,0.15); color: var(--coral); }

  /* ── TABS ── */
  .tabs { display: flex; gap: 4px; margin-bottom: 22px; }
  .tab {
    padding: 8px 18px; border-radius: 50px;
    font-size: 13px; cursor: pointer; transition: all 0.2s;
    color: var(--muted); border: 1px solid transparent;
  }
  .tab:hover { color: var(--text); border-color: var(--border); }
  .tab.active { background: rgba(124,110,255,0.2); color: var(--accent2); border-color: rgba(124,110,255,0.3); }

  /* scroll */
  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--dim); border-radius: 10px; }

  /* Separator */
  .sep { height: 1px; background: var(--border); margin: 20px 0; }

  /* Legend */
  .legend { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 14px; }
  .legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--muted); }
  .legend-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }

  /* Full-width card */
  .card-full { grid-column: 1 / -1; }

  /* fade-in */
  @keyframes fadeUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:none; } }
  .stat-card, .card { animation: fadeUp 0.4s ease both; }
  .stat-card:nth-child(1) { animation-delay: 0.05s; }
  .stat-card:nth-child(2) { animation-delay: 0.1s; }
  .stat-card:nth-child(3) { animation-delay: 0.15s; }
  .stat-card:nth-child(4) { animation-delay: 0.2s; }
</style>
</head>
<body>
<div class="app">

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="logo">
    <div class="logo-mark">Edu<span>Pulse</span></div>
    <div class="logo-sub">Student Tracker</div>
  </div>

  <nav class="nav">
    <div class="nav-label">Menu</div>
    <div class="nav-item active"><span class="nav-icon">◈</span> Dashboard</div>
    <div class="nav-item"><span class="nav-icon">◉</span> Performance</div>
    <div class="nav-item"><span class="nav-icon">◎</span> Attendance</div>
    <div class="nav-item"><span class="nav-icon">⬡</span> Reports</div>
    <div class="nav-item"><span class="nav-icon">⊕</span> Add Student</div>

    <div class="nav-label" style="margin-top:16px;">Students</div>
  </nav>

  <div class="student-list" id="sidebarList"></div>
</aside>

<!-- MAIN -->
<main class="main">
  <div class="topbar">
    <div>
      <div class="page-title">Student <span>Overview</span></div>
      <div style="font-size:13px;color:var(--muted);margin-top:4px;">Academic Year 2024–25 · Class 10</div>
    </div>
    <div style="display:flex;gap:10px;align-items:center;">
      <div class="search-bar">🔍 &nbsp;Search students...</div>
      <div style="width:36px;height:36px;border-radius:50%;background:var(--surface2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;">⚙</div>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats-grid">
    <div class="stat-card c1">
      <div class="stat-icon">◈</div>
      <div class="stat-label">Total Students</div>
      <div class="stat-value" style="color:var(--accent2);">20</div>
      <div class="stat-sub">Enrolled this year</div>
    </div>
    <div class="stat-card c2">
      <div class="stat-icon">⬟</div>
      <div class="stat-label">Class Average</div>
      <div class="stat-value" style="color:var(--teal);" id="classAvg">—</div>
      <div class="stat-sub">Across all subjects</div>
    </div>
    <div class="stat-card c3">
      <div class="stat-icon">⊛</div>
      <div class="stat-label">Avg Attendance</div>
      <div class="stat-value" style="color:var(--coral);" id="classAtt">—</div>
      <div class="stat-sub">Present days</div>
    </div>
    <div class="stat-card c4">
      <div class="stat-icon">✦</div>
      <div class="stat-label">Top Performer</div>
      <div class="stat-value" style="color:var(--amber);font-size:18px;padding-top:6px;" id="topStudent">—</div>
      <div class="stat-sub" id="topScore">—</div>
    </div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <div class="tab active" onclick="showTab('overview',this)">Overview</div>
    <div class="tab" onclick="showTab('subjects',this)">Subjects</div>
    <div class="tab" onclick="showTab('attendance',this)">Attendance</div>
    <div class="tab" onclick="showTab('rankings',this)">Rankings</div>
  </div>

  <!-- TAB: OVERVIEW -->
  <div id="tab-overview">
    <div class="grid-2">
      <div class="card" style="grid-column:1/2">
        <div class="card-title"><span class="dot" style="background:var(--accent)"></span>Class Performance Trend</div>
        <div class="legend" id="legendPerf"></div>
        <div class="chart-wrap" style="height:220px"><canvas id="chartTrend" role="img" aria-label="Line chart of subject performance trends over semesters">Subject performance trend chart.</canvas></div>
      </div>
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--teal)"></span>Score Distribution</div>
        <div class="chart-wrap" style="height:220px"><canvas id="chartDist" role="img" aria-label="Bar chart showing score distribution across grade bands">Score distribution across grade bands.</canvas></div>
      </div>
    </div>

    <div class="grid-2">
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--amber)"></span>Subject Averages</div>
        <div class="chart-wrap" style="height:200px"><canvas id="chartSubAvg" role="img" aria-label="Radar chart of average scores per subject">Subject averages radar chart.</canvas></div>
      </div>
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--pink)"></span>Selected Student Detail</div>
        <div id="detailPanel">
          <div style="text-align:center;padding:40px 0;color:var(--dim);font-size:13px;">← Select a student from the sidebar</div>
        </div>
      </div>
    </div>
  </div>

  <!-- TAB: SUBJECTS -->
  <div id="tab-subjects" style="display:none">
    <div class="grid-3">
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--accent)"></span>Mathematics</div>
        <div class="chart-wrap" style="height:180px"><canvas id="chartMath" role="img" aria-label="Bar chart for Mathematics scores">Mathematics scores.</canvas></div>
      </div>
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--teal)"></span>Science</div>
        <div class="chart-wrap" style="height:180px"><canvas id="chartSci" role="img" aria-label="Bar chart for Science scores">Science scores.</canvas></div>
      </div>
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--coral)"></span>English</div>
        <div class="chart-wrap" style="height:180px"><canvas id="chartEng" role="img" aria-label="Bar chart for English scores">English scores.</canvas></div>
      </div>
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--amber)"></span>History</div>
        <div class="chart-wrap" style="height:180px"><canvas id="chartHist" role="img" aria-label="Bar chart for History scores">History scores.</canvas></div>
      </div>
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--blue)"></span>Computer Science</div>
        <div class="chart-wrap" style="height:180px"><canvas id="chartCS" role="img" aria-label="Bar chart for Computer Science scores">Computer Science scores.</canvas></div>
      </div>
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--green)"></span>Subject Comparison (Top 5)</div>
        <div class="chart-wrap" style="height:180px"><canvas id="chartTop5" role="img" aria-label="Grouped bar chart comparing top 5 students across subjects">Top 5 students comparison.</canvas></div>
      </div>
    </div>
  </div>

  <!-- TAB: ATTENDANCE -->
  <div id="tab-attendance" style="display:none">
    <div class="grid-2">
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--teal)"></span>Monthly Attendance (%)</div>
        <div class="chart-wrap" style="height:240px"><canvas id="chartAttMonth" role="img" aria-label="Line chart of monthly class attendance percentage">Monthly attendance.</canvas></div>
      </div>
      <div class="card">
        <div class="card-title"><span class="dot" style="background:var(--coral)"></span>Attendance by Student</div>
        <div class="chart-wrap" style="height:240px"><canvas id="chartAttStudent" role="img" aria-label="Horizontal bar chart of attendance by student">Student attendance.</canvas></div>
      </div>
    </div>
    <div class="card">
      <div class="card-title"><span class="dot" style="background:var(--amber)"></span>Attendance vs Performance</div>
      <div class="chart-wrap" style="height:240px"><canvas id="chartAttPerf" role="img" aria-label="Scatter chart showing correlation between attendance and performance">Attendance vs performance scatter.</canvas></div>
    </div>
  </div>

  <!-- TAB: RANKINGS -->
  <div id="tab-rankings" style="display:none">
    <div class="card">
      <div class="card-title"><span class="dot" style="background:var(--accent)"></span>Student Rankings — All Subjects</div>
      <div class="table-wrap">
        <table id="rankTable">
          <thead>
            <tr>
              <th>#</th>
              <th>Student</th>
              <th>Math</th>
              <th>Science</th>
              <th>English</th>
              <th>History</th>
              <th>CS</th>
              <th>Average</th>
              <th>Attendance</th>
              <th>Grade</th>
            </tr>
          </thead>
          <tbody id="rankBody"></tbody>
        </table>
      </div>
    </div>
  </div>

</main>
</div>

