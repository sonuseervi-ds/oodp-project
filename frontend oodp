const SUBJECT_COLORS = ['#7c6eff','#00d4aa','#ff6b6b','#ffb347','#4fc3f7'];
const MONTHS = ['Aug','Sep','Oct','Nov','Dec','Jan','Feb','Mar','Apr'];

