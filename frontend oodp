  {name:'Deepak Joshi',    scores:[72,75,70,73,78], att:85},
  {name:'Saranya Venkat',  scores:[87,83,92,80,89], att:91},
  {name:'Mohan Das',       scores:[64,58,67,61,55], att:72},
  {name:'Kavitha Suresh',  scores:[96,97,94,98,99], att:100},
];

const AVATAR_COLORS = [
  ['#7c6eff','#1a1530'],['#00d4aa','#00342a'],['#ff6b6b','#3a1010'],
  ['#ffb347','#3a2800'],['#4fc3f7','#00274a'],['#f06292','#3a0020'],
  ['#69f0ae','#003a1a'],['#b8aaff','#1a1040'],['#ffd47a','#3a2a00'],
  ['#a5d6a7','#003a02'],
];

function avg(arr) { return Math.round(arr.reduce((a,b)=>a+b,0)/arr.length); }

function gradeInfo(score) {
  if(score>=90) return {g:'A+',c:'var(--green)'};
  if(score>=80) return {g:'A', c:'var(--teal)'};
  if(score>=70) return {g:'B', c:'var(--blue)'};
  if(score>=60) return {g:'C', c:'var(--amber)'};
  return {g:'D', c:'var(--coral)'};
}

function perfClass(score) {
  if(score>=90) return 'perf-A';
  if(score>=80) return 'perf-A';
  if(score>=70) return 'perf-B';
  if(score>=60) return 'perf-C';
  return 'perf-D';
}

function initials(name) {
  return name.split(' ').map(n=>n[0]).join('').slice(0,2);
}

let selectedStudent = null;

// ── SIDEBAR ──
const sidebarList = document.getElementById('sidebarList');
const sorted = [...STUDENTS].map((s,i)=>({...s,idx:i})).sort((a,b)=>avg(b.scores)-avg(a.scores));

sorted.forEach((s,rank) => {
  const ac = AVATAR_COLORS[s.idx % AVATAR_COLORS.length];
  const gi = gradeInfo(avg(s.scores));
  const el = document.createElement('div');
  el.className = 'student-item';
  el.dataset.idx = s.idx;
  el.innerHTML = `
    <div class="student-avatar" style="background:${ac[1]};color:${ac[0]}">${initials(s.name)}</div>
    <div class="student-name">${s.name}</div>
    <div class="student-grade" style="background:rgba(124,110,255,0.1);color:${gi.c}">${gi.g}</div>
  `;
  el.addEventListener('click', () => selectStudent(s.idx, el));
  sidebarList.appendChild(el);
});

// ── STATS ──
const allAvg = Math.round(STUDENTS.reduce((a,s)=>a+avg(s.scores),0)/STUDENTS.length);
const allAtt = Math.round(STUDENTS.reduce((a,s)=>a+s.att,0)/STUDENTS.length);
const topS = [...STUDENTS].sort((a,b)=>avg(b.scores)-avg(a.scores))[0];

document.getElementById('classAvg').textContent = allAvg + '%';
document.getElementById('classAtt').textContent = allAtt + '%';
document.getElementById('topStudent').textContent = topS.name.split(' ')[0];
document.getElementById('topScore').textContent = avg(topS.scores) + '% average';

// ── TABS ──
function showTab(id, el) {
  ['overview','subjects','attendance','rankings'].forEach(t => {
    document.getElementById('tab-'+t).style.display = t===id?'':'none';
  });
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');

  if(id==='subjects' && !window._subChartsDone) { buildSubjectCharts(); window._subChartsDone=true; }
  if(id==='attendance' && !window._attChartsDone) { buildAttendanceCharts(); window._attChartsDone=true; }
  if(id==='rankings' && !window._rankDone) { buildRankings(); window._rankDone=true; }
}

// ── SELECT STUDENT ──
function selectStudent(idx, el) {
  document.querySelectorAll('.student-item').forEach(e=>e.classList.remove('selected'));
  el.classList.add('selected');
  selectedStudent = idx;
  renderDetail(idx);
  highlightRankRow(idx);
}

function renderDetail(idx) {
  const s = STUDENTS[idx];
  const ac = AVATAR_COLORS[idx % AVATAR_COLORS.length];
  const a = avg(s.scores);
  const gi = gradeInfo(a);
  let html = `
    <div class="detail-header">
      <div class="detail-avatar" style="background:${ac[1]};color:${ac[0]};width:52px;height:52px;font-size:18px;font-family:'Syne',sans-serif;font-weight:700;border-radius:50%;display:flex;align-items:center;justify-content:center;">${initials(s.name)}</div>
      <div>
        <div class="detail-name">${s.name}</div>
        <div class="detail-meta">Attendance: ${s.att}% &nbsp;·&nbsp; Rank: #${getRank(idx)+1}</div>
      </div>
      <div class="grade-badge" style="color:${gi.c};border-color:${gi.c};">${gi.g}</div>
    </div>
  `;
  SUBJECTS.forEach((sub,i) => {
    const sc = s.scores[i];
    html += `
      <div class="subject-row">
        <div class="subject-name">${sub}</div>
        <div class="subject-bar-wrap"><div class="subject-bar" style="width:${sc}%;background:${SUBJECT_COLORS[i]}"></div></div>
        <div class="subject-score" style="color:${SUBJECT_COLORS[i]}">${sc}</div>
      </div>`;
  });
  document.getElementById('detailPanel').innerHTML = html;
}

function getRank(idx) {
  return sorted.findIndex(s=>s.idx===idx);
}

function highlightRankRow(idx) {
  document.querySelectorAll('#rankBody tr').forEach(r=>{
    r.classList.toggle('selected-row', r.dataset.idx==idx);
  });
}

// ── CHART: TREND ──
const trendData = {
  labels: MONTHS,
  datasets: SUBJECTS.map((sub,i)=>({
    label: sub,
    data: MONTHS.map((_,m)=>Math.round(60+Math.random()*35+m*0.5)),
    borderColor: SUBJECT_COLORS[i],
    backgroundColor: 'transparent',
    borderWidth: 2,
    pointRadius: 3,
    pointBackgroundColor: SUBJECT_COLORS[i],
    tension: 0.4,
  }))
};

const legendDiv = document.getElementById('legendPerf');
SUBJECTS.forEach((sub,i) => {
  legendDiv.innerHTML += `<span class="legend-item"><span class="legend-dot" style="background:${SUBJECT_COLORS[i]}"></span>${sub}</span>`;
});

new Chart(document.getElementById('chartTrend'), {
  type:'line',
  data: trendData,
  options:{
    responsive:true, maintainAspectRatio:false,
    plugins:{ legend:{display:false} },
    scales:{
      x:{ grid:{color:'rgba(255,255,255,0.04)'}, ticks:{color:'#8b8aaa',font:{size:11}} },
      y:{ grid:{color:'rgba(255,255,255,0.04)'}, ticks:{color:'#8b8aaa',font:{size:11}}, min:50, max:100 }
    }
  }
});

// ── CHART: DISTRIBUTION ──
const bands = ['50–59','60–69','70–79','80–89','90–100'];
const bandCounts = [0,0,0,0,0];
STUDENTS.forEach(s=>{
  const a=avg(s.scores);
  if(a<60) bandCounts[0]++;
  else if(a<70) bandCounts[1]++;
  else if(a<80) bandCounts[2]++;
  else if(a<90) bandCounts[3]++;
  else bandCounts[4]++;
});

new Chart(document.getElementById('chartDist'),{
  type:'bar',
  data:{
    labels:bands,
    datasets:[{
      label:'Students',
      data:bandCounts,
      backgroundColor:['rgba(255,107,107,0.7)','rgba(255,179,71,0.7)','rgba(79,195,247,0.7)','rgba(0,212,170,0.7)','rgba(105,240,174,0.7)'],
      borderRadius:6,
    }]
  },
  options:{
    responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:false}},
    scales:{
      x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b8aaa',font:{size:11}}},
      y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b8aaa',font:{size:11}},beginAtZero:true,max:8}
    }
  }
});

// ── CHART: SUBJECT AVG RADAR ──
const subjectAvgs = SUBJECTS.map((_,i)=>Math.round(STUDENTS.reduce((a,s)=>a+s.scores[i],0)/STUDENTS.length));

new Chart(document.getElementById('chartSubAvg'),{
  type:'radar',
  data:{
    labels:SUBJECTS,
    datasets:[{
      label:'Class Avg',
      data:subjectAvgs,
      borderColor:'rgba(124,110,255,0.9)',
      backgroundColor:'rgba(124,110,255,0.12)',
      pointBackgroundColor:'rgba(124,110,255,1)',
      pointRadius:4,
      borderWidth:2,
    }]
  },
  options:{
    responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:false}},
    scales:{
      r:{
        grid:{color:'rgba(255,255,255,0.06)'},
        angleLines:{color:'rgba(255,255,255,0.06)'},
        pointLabels:{color:'#8b8aaa',font:{size:12}},
        ticks:{display:false},
        min:50,max:100
      }
    }
  }
});

// ── SUBJECT CHARTS ──
function buildSubjectCharts() {
  const names = STUDENTS.map(s=>s.name.split(' ')[0]);
  SUBJECTS.forEach((sub,si)=>{
    const ids=['chartMath','chartSci','chartEng','chartHist','chartCS'];
    const data=STUDENTS.map(s=>s.scores[si]);
    new Chart(document.getElementById(ids[si]),{
      type:'bar',
      data:{
        labels:names,
        datasets:[{
          label:sub,
          data:data,
          backgroundColor:STUDENTS.map(s=>{
            const v=s.scores[si];
            return v>=80?'rgba(105,240,174,0.65)':v>=70?'rgba(79,195,247,0.65)':v>=60?'rgba(255,179,71,0.65)':'rgba(255,107,107,0.65)';
          }),
          borderRadius:4,
        }]
      },
      options:{
        responsive:true,maintainAspectRatio:false,
        plugins:{legend:{display:false}},
        scales:{
          x:{grid:{display:false},ticks:{color:'#8b8aaa',font:{size:9},maxRotation:45}},
          y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b8aaa',font:{size:10}},min:40,max:100}
        }
      }
    });
  });

  // Top 5 comparison
  const top5 = sorted.slice(0,5);
  new Chart(document.getElementById('chartTop5'),{
    type:'bar',
    data:{
      labels:top5.map(s=>s.name.split(' ')[0]),
      datasets:SUBJECTS.map((sub,i)=>({
        label:sub,
        data:top5.map(s=>s.scores[i]),
        backgroundColor:SUBJECT_COLORS[i]+'cc',
        borderRadius:3,
      }))
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        x:{grid:{display:false},ticks:{color:'#8b8aaa',font:{size:10}}},
        y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b8aaa',font:{size:9}},min:60,max:100}
      }
    }
  });
}

// ── ATTENDANCE CHARTS ──
function buildAttendanceCharts() {
  const monthlyAtt = MONTHS.map((_,m)=>Math.round(82+Math.random()*16+m*0.4));
  new Chart(document.getElementById('chartAttMonth'),{
    type:'line',
    data:{
      labels:MONTHS,
      datasets:[{
        label:'Attendance %',
        data:monthlyAtt,
        borderColor:'#00d4aa',
        backgroundColor:'rgba(0,212,170,0.08)',
        fill:true,
        tension:0.4,
        pointRadius:4,
        pointBackgroundColor:'#00d4aa',
        borderWidth:2,
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b8aaa',font:{size:11}}},
        y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b8aaa',font:{size:11}},min:70,max:100}
      }
    }
  });

  new Chart(document.getElementById('chartAttStudent'),{
    type:'bar',
    data:{
      labels:STUDENTS.map(s=>s.name.split(' ')[0]),
      datasets:[{
        label:'Attendance %',
        data:STUDENTS.map(s=>s.att),
        backgroundColor:STUDENTS.map(s=>s.att>=90?'rgba(105,240,174,0.7)':s.att>=80?'rgba(79,195,247,0.7)':'rgba(255,107,107,0.7)'),
        borderRadius:4,
      }]
    },
    options:{
      indexAxis:'y',
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b8aaa',font:{size:10}},min:60,max:100},
        y:{grid:{display:false},ticks:{color:'#8b8aaa',font:{size:10}}}
      }
    }
  });

  // Scatter: attendance vs avg score
  new Chart(document.getElementById('chartAttPerf'),{
    type:'scatter',
    data:{
      datasets:[{
        label:'Students',
        data:STUDENTS.map(s=>({x:s.att,y:avg(s.scores)})),
        backgroundColor:'rgba(124,110,255,0.65)',
        pointRadius:7,
        pointHoverRadius:9,
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b8aaa',font:{size:11}},title:{display:true,text:'Attendance %',color:'#8b8aaa',font:{size:11}},min:60,max:105},
        y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#8b8aaa',font:{size:11}},title:{display:true,text:'Avg Score %',color:'#8b8aaa',font:{size:11}},min:50,max:105}
      }
    }
  });
}

// ── RANKINGS TABLE ──
function buildRankings() {
  const body = document.getElementById('rankBody');
  sorted.forEach((s,rank)=>{
    const a=avg(s.scores);
    const gi=gradeInfo(a);
    const ac=AVATAR_COLORS[s.idx%AVATAR_COLORS.length];
    const tr=document.createElement('tr');
    tr.dataset.idx=s.idx;
    tr.innerHTML=`
      <td><span class="rank-badge">${rank+1}</span></td>
      <td style="display:flex;align-items:center;gap:8px;min-height:40px;">
        <div style="width:26px;height:26px;border-radius:50%;background:${ac[1]};color:${ac[0]};display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;font-family:'Syne',sans-serif;">${initials(s.name)}</div>
        ${s.name}
      </td>
      ${s.scores.map((sc,i)=>`<td style="color:${SUBJECT_COLORS[i]};font-family:'DM Mono',monospace;font-size:13px">${sc}</td>`).join('')}
      <td style="font-family:'DM Mono',monospace;font-size:13px;font-weight:500;color:var(--text)">${a}%</td>
      <td style="font-family:'DM Mono',monospace;font-size:13px;color:${s.att>=90?'var(--green)':s.att>=80?'var(--blue)':'var(--coral)'}">${s.att}%</td>
      <td><span class="perf-pill ${a>=90?'perf-A':a>=80?'perf-A':a>=70?'perf-B':a>=60?'perf-C':'perf-D'}" style="color:${gi.c};background:${gi.c}22">${gi.g}</span></td>
    `;
    tr.addEventListener('click',()=>{
      const sideEl=[...document.querySelectorAll('.student-item')].find(e=>e.dataset.idx==s.idx);
      if(sideEl) selectStudent(s.idx,sideEl);
      showTab('overview',document.querySelector('.tab'));
      document.querySelectorAll('.tab')[0].classList.add('active');
      document.querySelectorAll('.tab').forEach((t,i)=>i>0&&t.classList.remove('active'));
    });
    body.appendChild(tr);
  });
}
</script>
</body>
</html>
